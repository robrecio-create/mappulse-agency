---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { services } from '../../data/site';
---

<Layout 
  title="Local SEO Services Gulf Coast MS | MapPulse"
  description="Complete local SEO services for Gulf Coast businesses. GBP optimization, citations, website design, review management, and monthly reporting. No contracts."
>
  <Header activePage="Services" />

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">What We Offer</span>
      <h1>Simple services. Real results.</h1>
      <p>Everything a Gulf Coast small business needs to show up online — no contracts, no jargon, no hidden fees.</p>
    </div>
  </section>

  <section class="section services-section">
    <div class="container">
      <div class="services-grid">
        {services.map(service => (
          <a href={`/services/${service.slug}/`} class:list={['service-card', { featured: service.featured }]}>
            {service.featured && <span class="featured-badge">★ Most Popular</span>}
            <span class="service-icon">{service.icon}</span>
            <h2>{service.name}</h2>
            <p>{service.tagline}</p>
            <span class="service-price">{service.price}</span>
            <span class="learn-more">Learn More →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container">
      <div class="cta-box">
        <h2>Not sure where to start?</h2>
        <p>Book a free 20-minute call. We'll tell you exactly what your business needs.</p>
        <a href="/contact/" class="btn btn-primary">Get a Free Audit →</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .page-hero {
    padding: 8rem 0 4rem;
    background: linear-gradient(135deg, #0a0f1a 0%, #1a1f35 100%);
    text-align: center;
    color: var(--white);
    position: relative;
    overflow: hidden;
  }

  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(6, 182, 212, 0.15) 0%, transparent 60%);
  }

  .page-hero .container {
    position: relative;
  }

  .page-hero h1 {
    margin: 0.75rem 0 1rem;
    color: var(--white);
  }

  .page-hero p {
    max-width: 600px;
    margin: 0 auto;
    color: rgba(255,255,255,0.7);
    font-size: 1.125rem;
  }

  .services-section {
    background: var(--blue-900);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .service-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 2rem;
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(10px);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255,255,255,0.1);
    transition: all 0.3s ease;
  }

  .service-card:hover {
    border-color: var(--teal-500);
    background: rgba(255,255,255,0.1);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }

  .service-card.featured {
    background: linear-gradient(135deg, rgba(6, 182, 212, 0.1) 0%, rgba(249, 115, 22, 0.05) 100%);
    border-color: var(--teal-500);
  }

  .service-card h2 {
    color: var(--white);
  }

  .service-card p {
    color: rgba(255,255,255,0.6);
  }

  .learn-more {
    color: var(--teal-400);
  }

  .featured-badge {
    position: absolute;
    top: -10px;
    right: 1.5rem;
    background: var(--teal-500);
    color: var(--white);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
  }

  .service-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .service-card h2 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .service-card p {
    color: var(--blue-600);
    margin-bottom: 1rem;
    flex-grow: 1;
  }

  .service-price {
    font-weight: 600;
    color: var(--teal-400);
    margin-bottom: 1rem;
  }

  .learn-more {
    font-weight: 500;
    color: var(--teal-400);
  }

  .cta-section {
    background: #0a0f1a;
  }

  .cta-box {
    text-align: center;
    padding: 4rem 2rem;
    background: var(--blue-900);
    border-radius: var(--radius-xl);
    color: var(--white);
  }

  .cta-box h2 {
    color: var(--white);
    margin-bottom: 1rem;
  }

  .cta-box p {
    opacity: 0.9;
    margin-bottom: 1.5rem;
  }
</style>
