---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../data/site';
---

<Layout 
  title="Contact MapPulse | Free Local SEO Audit"
  description="Get a free local SEO audit for your Gulf Coast business. Book a 20-minute call or send us a message. Same-day response guaranteed."
>
  <Header activePage="Contact" />

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Contact</span>
      <h1>Let's talk about<br/>your business.</h1>
      <p>Book a free 20-minute call or send us a message. We'll get back to you the same day.</p>
    </div>
  </section>

  <section class="section contact-section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h2>We're based right here on the Gulf Coast.</h2>
          <p>MapPulse is a local agency — not a call center, not a chatbot. When you reach out, you're talking to the person doing the work.</p>
          
          <div class="info-items">
            <div class="info-item">
              <span class="info-label">Service Area</span>
              <span class="info-value">Jackson, Harrison & Hancock Counties, MS</span>
            </div>
            <div class="info-item">
              <span class="info-label">Response Time</span>
              <span class="info-value">Same business day</span>
            </div>
            <div class="info-item">
              <span class="info-label">Email</span>
              <a href={`mailto:${SITE.email}`} class="info-value">{SITE.email}</a>
            </div>
          </div>

          <div class="calendly-cta">
            <h3>Prefer to book a call?</h3>
            <p>Free 20-Minute Discovery Call</p>
            <p class="calendly-desc">We'll look at your current online presence and tell you exactly what we'd do — no pitch, no pressure.</p>
            <a href={SITE.calendly} target="_blank" rel="noopener" class="btn btn-primary">📅 Book a Time on Calendly</a>
          </div>
        </div>

        <div class="contact-form-wrapper">
          <h3>Send us a message</h3>
          <p>We'll get back to you the same day.</p>
          
          <form class="contact-form" id="contact-form" action="/api/contact" method="POST">
            <div class="form-group">
              <label for="name">Your Name *</label>
              <input type="text" id="name" name="name" required />
            </div>
            <div class="form-group">
              <label for="email">Email Address *</label>
              <input type="email" id="email" name="email" required />
            </div>
            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone" />
            </div>
            <div class="form-group">
              <label for="business">Business Name</label>
              <input type="text" id="business" name="business" />
            </div>
            <div class="form-group">
              <label for="website">Current Website (if any)</label>
              <input type="url" id="website" name="website" placeholder="https://" />
            </div>
            <div class="form-group full-width">
              <label for="message">How can we help? *</label>
              <textarea id="message" name="message" rows="4" required></textarea>
            </div>
            <button type="submit" class="btn btn-primary full-width">Send Message →</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .page-hero {
    padding: 8rem 0 4rem;
    background: var(--blue-50);
    text-align: center;
  }

  .page-hero h1 {
    margin: 0.75rem 0 1rem;
  }

  .page-hero p {
    max-width: 500px;
    margin: 0 auto;
    color: var(--blue-600);
    font-size: 1.125rem;
  }

  .contact-section {
    background: var(--white);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  .contact-info h2 {
    margin-bottom: 1rem;
  }

  .contact-info > p {
    color: var(--blue-600);
    margin-bottom: 2rem;
  }

  .info-items {
    margin-bottom: 2.5rem;
  }

  .info-item {
    padding: 1rem 0;
    border-bottom: 1px solid var(--blue-100);
  }

  .info-label {
    display: block;
    font-size: 0.875rem;
    color: var(--blue-500);
    margin-bottom: 0.25rem;
  }

  .info-value {
    font-weight: 600;
    color: var(--blue-900);
  }

  a.info-value {
    color: var(--teal-600);
  }

  a.info-value:hover {
    text-decoration: underline;
  }

  .calendly-cta {
    padding: 2rem;
    background: var(--blue-50);
    border-radius: var(--radius-lg);
  }

  .calendly-cta h3 {
    font-size: 1.125rem;
    margin-bottom: 0.25rem;
  }

  .calendly-cta > p:first-of-type {
    font-weight: 600;
    color: var(--teal-600);
    margin-bottom: 0.5rem;
  }

  .calendly-desc {
    color: var(--blue-600);
    font-size: 0.9375rem;
    margin-bottom: 1.5rem;
  }

  .contact-form-wrapper {
    padding: 2rem;
    background: var(--blue-50);
    border-radius: var(--radius-lg);
  }

  .contact-form-wrapper h3 {
    margin-bottom: 0.25rem;
  }

  .contact-form-wrapper > p {
    color: var(--blue-600);
    margin-bottom: 1.5rem;
  }

  .contact-form {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-group label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--blue-700);
  }

  .form-group input,
  .form-group textarea {
    padding: 0.75rem 1rem;
    border: 1px solid var(--blue-200);
    border-radius: var(--radius-md);
    font-size: 1rem;
    font-family: inherit;
    transition: border-color 0.2s;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--teal-500);
  }

  .full-width {
    grid-column: 1 / -1;
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }

    .contact-form {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
