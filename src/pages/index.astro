---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE, services, locations } from '../data/site';
---

<Layout 
  title="Local SEO Agency Gulf Coast MS | MapPulse"
  description="Gulf Coast Local SEO agency helping Mississippi businesses rank on Google Maps. GBP optimization, local SEO, and websites that convert. Ocean Springs, Biloxi, Gulfport."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "MapPulse",
    "description": "Gulf Coast Local SEO agency",
    "url": "https://www.mappulse.agency",
    "telephone": SITE.phone,
    "email": SITE.email,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Ocean Springs",
      "addressRegion": "MS",
      "addressCountry": "US"
    },
    "areaServed": locations.map(l => ({
      "@type": "City",
      "name": l.name + ", Mississippi"
    }))
  })} />

  <Header activePage="Home" />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-gradient"></div>
      <div class="hero-glow hero-glow-1"></div>
      <div class="hero-glow hero-glow-2"></div>
      <div class="hero-grid"></div>
    </div>
    <div class="container hero-container">
      <div class="hero-content">
        <span class="eyebrow">Gulf Coast Local SEO</span>
        <h1>Put Your Business<br/>on the <span class="gradient-text">Map.</span></h1>
        <p class="hero-subtitle">
          Most local businesses in Mississippi are invisible online. MapPulse fixes that — with real local SEO, Google Business Profile optimization, and websites built to rank.
        </p>
        <div class="hero-ctas">
          <a href="/contact/" class="btn btn-primary btn-glow">Get a Free Audit →</a>
          <a href="/services/full-seo-package/" class="btn btn-secondary">See Our Services</a>
        </div>
        <div class="hero-trust">
          <span>Trusted tools & platforms:</span>
          <div class="trust-logos">
            <span>Google Business Profile</span>
            <span>Local SEO</span>
            <span>WordPress</span>
          </div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-card hero-card-1">
          <span class="card-icon">📍</span>
          <span class="card-label">Google Maps</span>
          <span class="card-stat">3-Pack Ranking</span>
        </div>
        <div class="hero-card hero-card-2">
          <span class="card-icon">⭐</span>
          <span class="card-label">Reviews</span>
          <span class="card-stat">+127% clicks</span>
        </div>
        <div class="hero-card hero-card-3">
          <span class="card-icon">📈</span>
          <span class="card-label">Traffic</span>
          <span class="card-stat">↑ 340%</span>
        </div>
        <div class="hero-map-pin"></div>
      </div>
    </div>
  </section>

  <!-- Problem Section -->
  <section class="section problem-section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">The Problem</span>
        <h2>Most local businesses are invisible online.</h2>
        <p>Your customers are searching Google right now. If you're not showing up, someone else is getting the call.</p>
      </div>
      
      <div class="problems-grid">
        <div class="problem-card">
          <span class="problem-num">01</span>
          <h3>No Google Maps presence</h3>
          <p>72% of local searches end with a store visit. If you're not in the 3-Pack, you're handing those customers to your competitors.</p>
        </div>
        <div class="problem-card">
          <span class="problem-num">02</span>
          <h3>Outdated or missing website</h3>
          <p>A slow, mobile-unfriendly site kills trust instantly. Local buyers judge your business by how it looks online before they ever call.</p>
        </div>
        <div class="problem-card">
          <span class="problem-num">03</span>
          <h3>No review strategy</h3>
          <p>Businesses with 50+ reviews get 4x more clicks. Most local businesses have no system for collecting and responding to reviews.</p>
        </div>
        <div class="problem-card">
          <span class="problem-num">04</span>
          <h3>Zero content or citations</h3>
          <p>Google ranks businesses it can verify. Inconsistent NAP data and no local content signals mean you stay buried on page 3.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="section services-section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Our Services</span>
        <h2>Simple services. Real results.</h2>
        <p>Everything a Gulf Coast small business needs to show up online — no contracts, no jargon, no hidden fees.</p>
      </div>

      <div class="services-grid">
        {services.slice(0, 6).map(service => (
          <a href={`/services/${service.slug}/`} class:list={['service-card', { featured: service.featured }]}>
            {service.featured && <span class="featured-badge">★ Most Popular</span>}
            <span class="service-icon">{service.icon}</span>
            <h3>{service.name}</h3>
            <p>{service.tagline}</p>
            <span class="service-price">{service.price}</span>
          </a>
        ))}
      </div>

      <div class="services-cta">
        <a href="/services/" class="btn btn-outline">View All Services →</a>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="section process-section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">The Process</span>
        <h2>How MapPulse works</h2>
        <p>Three steps from invisible to in-demand. No long contracts, no confusing reports, no runaround.</p>
      </div>

      <div class="process-steps">
        <div class="process-step">
          <span class="step-num">1</span>
          <h3>Free Audit</h3>
          <p>We review your Google presence, website, citations, and reviews — and tell you exactly what's costing you customers.</p>
        </div>
        <div class="process-step">
          <span class="step-num">2</span>
          <h3>Custom Strategy</h3>
          <p>You get a clear plan tailored to your business. We explain exactly what we'll do, why, and what results to expect.</p>
        </div>
        <div class="process-step">
          <span class="step-num">3</span>
          <h3>Real Results</h3>
          <p>We handle everything. Monthly reports show your rankings, traffic, and calls — in plain English, not agency jargon.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Locations Section -->
  <section class="section locations-section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Our Territory</span>
        <h2>We know the Gulf Coast.</h2>
        <p>We're not a national agency sending templated reports from out of state. MapPulse is based right here on the Mississippi Gulf Coast.</p>
      </div>

      <div class="locations-grid">
        {locations.map(loc => (
          <a href={`/locations/${loc.slug}-seo/`} class="location-tag">
            📍 {loc.name}
          </a>
        ))}
      </div>

      <div class="value-props">
        <div class="value-prop">
          <span class="value-icon">🤝</span>
          <h4>We already have your listing</h4>
          <p>Every business in our directory network is a warm lead. We know your business before we ever talk.</p>
        </div>
        <div class="value-prop">
          <span class="value-icon">💰</span>
          <h4>Transparent pricing</h4>
          <p>No retainer traps. No hidden fees. No long-term lock-ins. You know exactly what you're paying for.</p>
        </div>
        <div class="value-prop">
          <span class="value-icon">📊</span>
          <h4>Results you can see</h4>
          <p>Monthly reports with real numbers: rankings, calls, traffic. Not vanity metrics or agency fluff.</p>
        </div>
        <div class="value-prop">
          <span class="value-icon">🌊</span>
          <h4>Gulf Coast rooted</h4>
          <p>We know Ocean Springs, we know Pascagoula. This is our home — we have skin in the game.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-box">
        <h2>Ready to put your business<br/>on the map?</h2>
        <p>Start with a free local SEO audit. We'll show you exactly where you stand and what it would take to rank on Google.</p>
        <p class="cta-note">No cost. No commitment. Just a straight answer about where your business stands online.</p>
        <a href="/contact/" class="btn btn-primary btn-lg">Get Your Free Audit →</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* Hero */
  .hero {
    position: relative;
    padding: 8rem 0 5rem;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    color: var(--white);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #0a0f1a 0%, #1a1f35 50%, #0f1629 100%);
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse 80% 50% at 50% -20%, rgba(6, 182, 212, 0.15) 0%, transparent 50%),
      radial-gradient(ellipse 60% 40% at 100% 50%, rgba(249, 115, 22, 0.1) 0%, transparent 50%);
  }

  .hero-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    animation: float 8s ease-in-out infinite;
  }

  .hero-glow-1 {
    width: 400px;
    height: 400px;
    background: rgba(6, 182, 212, 0.2);
    top: -100px;
    right: 10%;
    animation-delay: 0s;
  }

  .hero-glow-2 {
    width: 300px;
    height: 300px;
    background: rgba(249, 115, 22, 0.15);
    bottom: -50px;
    right: 30%;
    animation-delay: -4s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-20px) scale(1.05); }
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
  }

  .hero-container {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-content {
    max-width: 600px;
  }

  .hero h1 {
    margin-bottom: 1.5rem;
    color: var(--white);
    font-size: clamp(2.5rem, 6vw, 4rem);
  }

  .gradient-text {
    background: linear-gradient(135deg, #06b6d4 0%, #22d3ee 50%, #f97316 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero .eyebrow {
    color: var(--teal-400);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: rgba(255,255,255,0.7);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .btn-glow {
    box-shadow: 0 0 20px rgba(6, 182, 212, 0.4);
    transition: all 0.3s ease;
  }

  .btn-glow:hover {
    box-shadow: 0 0 30px rgba(6, 182, 212, 0.6);
  }

  .hero-trust {
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .hero-trust > span:first-child {
    display: block;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.5);
    margin-bottom: 0.75rem;
  }

  .trust-logos {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .trust-logos span {
    font-weight: 600;
    color: var(--white);
    font-size: 0.9375rem;
  }

  /* Hero Visual */
  .hero-visual {
    display: none;
    position: relative;
    height: 400px;
  }

  .hero-card {
    position: absolute;
    padding: 1.25rem 1.5rem;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    animation: cardFloat 6s ease-in-out infinite;
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }

  .hero-card-1 {
    top: 10%;
    right: 10%;
    animation-delay: 0s;
  }

  .hero-card-2 {
    top: 45%;
    right: 30%;
    animation-delay: -2s;
  }

  .hero-card-3 {
    top: 70%;
    right: 5%;
    animation-delay: -4s;
  }

  @keyframes cardFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-10px) rotate(1deg); }
  }

  .card-icon {
    font-size: 1.5rem;
  }

  .card-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255,255,255,0.6);
  }

  .card-stat {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--teal-400);
  }

  .hero-map-pin {
    position: absolute;
    top: 30%;
    right: 50%;
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, #06b6d4, #f97316);
    border-radius: 50% 50% 50% 0;
    transform: rotate(-45deg);
    animation: pinBounce 2s ease-in-out infinite;
    box-shadow: 0 10px 30px rgba(6, 182, 212, 0.4);
  }

  .hero-map-pin::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 20px;
    height: 20px;
    background: white;
    border-radius: 50%;
  }

  @keyframes pinBounce {
    0%, 100% { transform: rotate(-45deg) translateY(0); }
    50% { transform: rotate(-45deg) translateY(-15px); }
  }

  @media (min-width: 1024px) {
    .hero-container {
      grid-template-columns: 1fr 1fr;
    }

    .hero-visual {
      display: block;
    }
  }

  /* Problems */
  .problem-section {
    background: var(--white);
  }

  .problems-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem;
  }

  .problem-card {
    padding: 2rem;
    background: var(--blue-900);
    border-radius: var(--radius-lg);
    color: var(--white);
  }

  .problem-card h3 {
    color: var(--white);
  }

  .problem-num {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--teal-600);
    margin-bottom: 1rem;
  }

  .problem-card h3 {
    font-size: 1.125rem;
    margin-bottom: 0.75rem;
    color: var(--white);
  }

  .problem-card p {
    color: var(--blue-400);
    font-size: 0.9375rem;
  }

  /* Services */
  .services-section {
    background: var(--blue-900);
    color: var(--white);
  }

  .services-section .section-header h2,
  .services-section .section-header p {
    color: var(--white);
  }

  .services-section .eyebrow {
    color: var(--teal-400);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .service-card {
    position: relative;
    padding: 2rem;
    background: var(--blue-800);
    border-radius: var(--radius-lg);
    border: 1px solid var(--blue-700);
    transition: all 0.3s ease;
  }

  .service-card:hover {
    transform: translateY(-4px);
    border-color: var(--teal-500);
  }

  .service-card.featured {
    border-color: var(--teal-500);
    background: linear-gradient(135deg, var(--blue-800) 0%, rgba(20, 184, 166, 0.1) 100%);
  }

  .featured-badge {
    position: absolute;
    top: -10px;
    right: 1.5rem;
    background: var(--teal-500);
    color: var(--white);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
  }

  .service-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 1rem;
  }

  .service-card h3 {
    color: var(--white);
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
  }

  .service-card p {
    color: var(--blue-400);
    font-size: 0.9375rem;
    margin-bottom: 1rem;
  }

  .service-price {
    font-weight: 600;
    color: var(--teal-400);
  }

  .services-cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  .services-section .btn-outline {
    border-color: var(--white);
    color: var(--white);
  }

  .services-section .btn-outline:hover {
    background: var(--white);
    color: var(--blue-900);
  }

  /* Process */
  .process-section {
    background: var(--white);
  }

  .process-steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .process-step {
    text-align: center;
    padding: 2rem;
  }

  .step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: var(--teal-500);
    color: var(--white);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.25rem;
    border-radius: var(--radius-full);
    margin-bottom: 1.5rem;
  }

  .process-step h3 {
    margin-bottom: 0.75rem;
  }

  .process-step p {
    color: var(--blue-600);
  }

  /* Locations */
  .locations-section {
    background: var(--blue-50);
  }

  .locations-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .location-tag {
    display: inline-block;
    padding: 0.75rem 1.25rem;
    background: var(--white);
    border-radius: var(--radius-full);
    font-weight: 500;
    color: var(--blue-800);
    box-shadow: var(--shadow-sm);
    transition: all 0.2s ease;
  }

  .location-tag:hover {
    background: var(--teal-500);
    color: var(--white);
    transform: translateY(-2px);
  }

  .value-props {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
  }

  .value-prop {
    text-align: center;
    padding: 1.5rem;
  }

  .value-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 1rem;
  }

  .value-prop h4 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .value-prop p {
    font-size: 0.9375rem;
    color: var(--blue-600);
  }

  /* CTA */
  .cta-section {
    background: var(--white);
  }

  .cta-box {
    text-align: center;
    padding: 4rem 2rem;
    background: linear-gradient(135deg, var(--teal-600) 0%, var(--teal-500) 100%);
    border-radius: var(--radius-xl);
    color: var(--white);
  }

  .cta-box h2 {
    color: var(--white);
    margin-bottom: 1rem;
  }

  .cta-box p {
    max-width: 600px;
    margin: 0 auto 1.5rem;
    opacity: 0.9;
  }

  .cta-note {
    font-size: 0.9375rem;
    opacity: 0.8;
  }

  .cta-box .btn {
    margin-top: 1rem;
    background: var(--white);
    color: var(--teal-600);
  }

  .cta-box .btn:hover {
    background: var(--blue-900);
    color: var(--white);
  }

  .btn-lg {
    padding: 1rem 2rem;
    font-size: 1rem;
  }
</style>
